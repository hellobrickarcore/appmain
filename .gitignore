# HelloBrick Master Production Gitignore

# 1. Broad Ignores (Dependencies & Bloat)
node_modules/
**/node_modules/
.pnp
.pnp.js
.DS_Store
Thumbs.db
*.log
.env*
.capacitor/
*.zip
*.tar
*.gz

# 2. Large Binary Models & Data (Too big for GitHub)
server/models/
server/data/
server/runs/
**/*.pt
**/*.onnx
**/*.pth
**/*.weights
**/*.h5

# 3. Native Build Artifacts (Reproducible)
ios/Pods/
ios/build/
ios/DerivedData/
android/.gradle/
android/app/build/
android/build/
*.xcresult

# 4. Web Build Artifacts (Reproducible/Generated)
# We might want to keep 'dist' if the user specifically wants the 'build'
# But usually .next is too large.
web/.next/
**/.next/
out/

# 5. Whitelist everything else
# (Git includes by default unless ignored above)
