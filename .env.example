# ===========================================
# HelloBrick Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# --- Gemini AI ---
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# --- Detection API ---
VITE_DETECTION_API_URL=http://localhost:3003/api

# --- RevenueCat (Subscription Management) ---
# Get your iOS public SDK key from: https://app.revenuecat.com → Project → Settings → API Keys
VITE_REVENUECAT_IOS_KEY=appl_your_ios_key_here
VITE_REVENUECAT_GOOGLE_KEY=goog_your_google_key_here

# --- Supabase (Auth + Database) ---
# Get these from: https://supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# --- Server-Side Only (not prefixed with VITE_) ---
# RevenueCat webhook authorization bearer token
REVENUECAT_WEBHOOK_SECRET=your_webhook_secret_here
